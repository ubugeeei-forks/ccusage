{
	"name": "@ccusage/docs",
	"version": "20.0.1",
	"private": true,
	"description": "Documentation for coding (agent) CLI usage analysis with ccusage",
	"type": "module",
	"scripts": {
		"build": "cp ../apps/ccusage/config-schema.json public/config-schema.json && vitepress build",
		"deploy": "wrangler deploy",
		"dev": "cp ../apps/ccusage/config-schema.json public/config-schema.json && vitepress dev",
		"format": "oxfmt --write .",
		"lint": "oxlint .",
		"preview": "vitepress preview",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@ryoppippi/vite-plugin-cloudflare-redirect": "catalog:docs",
		"@types/bun": "catalog:types",
		"@types/react": "catalog:types",
		"vitepress": "catalog:docs",
		"vitepress-plugin-group-icons": "catalog:docs",
		"vitepress-plugin-llms": "catalog:docs",
		"wrangler": "catalog:docs"
	},
	"engines": {
		"node": ">=22.11.0"
	}
}
